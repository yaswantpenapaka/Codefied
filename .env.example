# Copy to .env and fill in your values:
#   cp .env.example .env

# MongoDB Atlas connection string (free M0 tier)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Google Gemini API key (AI code review)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Frontend URL for CORS (comma-separated for multiple origins)
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-app.vercel.app

# Cookie secure flag — false for local http, true for production https
COOKIE_SECURE=false

# Cookie SameSite — use lax for Vercel /api proxy (Safari & US browsers friendly)
# COOKIE_SAME_SITE=lax

# Redis — PM2 on host uses 127.0.0.1; Docker backend profile uses REDIS_HOST=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# t3.small production setup: bash scripts/setup-t3-small.sh
# Auth tokens are HTTP-only cookies (no localStorage)